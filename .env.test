# ─── StockFlow Payment Test Suite ────────────────────────────────────────────
# Copy this file and fill in the values below, then run:
#   node scripts/test-payments.mjs
#
# IMPORTANT: Use TEST mode keys only. Never put live keys here.
# ─────────────────────────────────────────────────────────────────────────────

# From Supabase Dashboard → Settings → API → service_role (secret) key
SUPABASE_SERVICE_ROLE_KEY=eyJ_REPLACE_ME

# From Stripe Dashboard → toggle to TEST MODE → Developers → API keys → Secret key
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# From `stripe listen --forward-to ...` output (the whsec_... line it prints on start)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Email of any existing account in your app (used to look up the test user in the DB)
TEST_USER_EMAIL=tibeaudegrauwe@gmail.com
